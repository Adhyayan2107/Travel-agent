# Application
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/travel_agent?schema=public"
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=travel_agent

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_URL=http://localhost:6333

# LLM Providers (only GROQ_API_KEY is needed - it's free!)
GROQ_API_KEY=gsk_...                   # Free at console.groq.com — REQUIRED
OPENAI_API_KEY=sk-...                  # Optional
GEMINI_API_KEY=AIza...                 # Optional
GOOGLE_PROJECT_ID=my-project           # Optional
OPENROUTER_API_KEY=sk-or-...           # Optional

# Default provider
LLM_DEFAULT_PROVIDER=groq              # groq | openai | google | openrouter

# RTK - keep disabled
RTK_ENABLED=false
RTK_MAX_OUTPUT_BYTES=51200              # 50KB cap after compression

# External Search APIs
AMADEUS_API_KEY=...
AMADEUS_API_SECRET=...
BOOKING_COM_API_KEY=...
GOOGLE_PLACES_API_KEY=...
